--- Explicit Join via Nouns ---
Query: names of directors and titles of movies
SQL: SELECT Actor.name, Movie.title FROM Actor JOIN Cast ON Actor.aid = Cast.aid JOIN Movie ON Cast.mid = Movie.mid JOIN Directed ON Movie.mid = Directed.mid JOIN Director ON Directed.did = Director.did;
Structure: {
  "select": [
    "Actor.name",
    "Movie.title"
  ],
  "from": [
    "Actor",
    "Movie",
    "Director"
  ],
  "where": [],
  "group_by": [],
  "order_by": [],
  "limit": null,
  "joins": [
    "JOIN Cast ON Actor.aid = Cast.aid",
    "JOIN Movie ON Cast.mid = Movie.mid",
    "JOIN Directed ON Movie.mid = Directed.mid",
    "JOIN Director ON Directed.did = Director.did"
  ]
}
